{
  "name": "典雅金",
  "id": "elegant_gold",
  "description": "高端典雅的金黑配色，适用于高端商务、投融资路演类赛事",
  "colors": {
    "primary": "#1A1A1A",
    "primary_light": "#D4A017",
    "primary_gradient": "linear-gradient(135deg, #1A1A1A, #3D2B00)",
    "secondary": "#2D2D2D",
    "accent": "#FFD700",
    "background": "#FFFDF5",
    "text_primary": "#1A1A1A",
    "text_secondary": "#4A4A4A",
    "table_header_bg": "#1A1A1A",
    "table_header_text": "#FFD700",
    "border_light": "#E8DCC8",
    "success": "#4CAF50",
    "warning": "#FF9800",
    "danger": "#E53935"
  },
  "typography": {
    "cover_title": {"font": "思源宋体 Bold", "size": "60pt", "color": "#FFD700"},
    "cover_subtitle": {"font": "思源宋体", "size": "22pt", "color": "#D4C88A"},
    "chapter_title": {"font": "黑体", "size": "二号(22pt)", "align": "center", "color": "#1A1A1A"},
    "section_title": {"font": "黑体", "size": "三号(16pt)", "align": "left", "color": "#2D2D2D"},
    "subsection_title": {"font": "黑体", "size": "四号(14pt)", "align": "left", "color": "#D4A017"},
    "body_text": {"font": "微软雅黑", "size": "小四(12pt)", "line_height": 1.6, "color": "#1A1A1A"},
    "body_text_english": {"font": "Georgia", "size": "12pt"},
    "caption": {"font": "微软雅黑", "size": "9pt", "color": "#8C8C8C"},
    "header_footer": {"font": "微软雅黑", "size": "9pt", "color": "#BFA980"}
  },
  "layout": {
    "page_margin_top": "3.5cm", "page_margin_bottom": "3.2cm",
    "page_margin_left": "3.5cm", "page_margin_right": "3.2cm",
    "header_content": "{project_name}",
    "footer_content": "- {page_number} -"
  },
  "table_style": {
    "type": "典雅边框表", "header_bg": "#1A1A1A", "header_text": "#FFD700",
    "body_font_size": "10pt", "border_style": "1pt solid gold",
    "alternate_row_bg": "#FFFDF0"
  },
  "chart_style": {
    "default_type": "elegant_dark",
    "color_palette": ["#D4A017", "#1A1A1A", "#C0C0C0", "#FFD700", "#8B7355"],
    "font_family": "Microsoft YaHei", "grid_style": "light_dotted",
    "legend_position": "bottom", "title_font_size": 15
  },
  "image_specs": {
    "background_news_ratio": "20:10", "tech_diagram_style": "elegant_gold",
    "cover_logo_position": "center", "min_dpi": 300,
    "figure_numbering": "图{chapter}-{index}"
  },
  "css_template": "elegant_gold_style.css"
}
